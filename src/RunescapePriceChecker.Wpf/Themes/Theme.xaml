<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="InkColor">#27241F</Color>
    <Color x:Key="MutedColor">#716A5F</Color>
    <Color x:Key="PaperColor">#F3EEDF</Color>
    <Color x:Key="PaperLightColor">#FBF8EF</Color>
    <Color x:Key="LineColor">#DED4C1</Color>
    <Color x:Key="GoldColor">#A16F1D</Color>
    <Color x:Key="GoldDarkColor">#754B10</Color>
    <Color x:Key="SidebarColor">#1F2420</Color>
    <Color x:Key="SidebarMutedColor">#ABB1A7</Color>
    <Color x:Key="PositiveColor">#27734A</Color>
    <Color x:Key="NegativeColor">#A33B32</Color>

    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="PaperBrush" Color="{StaticResource PaperColor}" />
    <SolidColorBrush x:Key="PaperLightBrush" Color="{StaticResource PaperLightColor}" />
    <SolidColorBrush x:Key="LineBrush" Color="{StaticResource LineColor}" />
    <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}" />
    <SolidColorBrush x:Key="GoldDarkBrush" Color="{StaticResource GoldDarkColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="{StaticResource SidebarMutedColor}" />
    <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource PositiveColor}" />
    <SolidColorBrush x:Key="NegativeBrush" Color="{StaticResource NegativeColor}" />

    <FontFamily x:Key="BodyFont">Segoe UI</FontFamily>
    <FontFamily x:Key="DisplayFont">Georgia</FontFamily>

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Background" Value="{StaticResource PaperBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="Kicker" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
    </Style>

    <Style x:Key="Panel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PaperLightBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GoldBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource GoldDarkBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="#EEE4D0" />
        <Setter Property="Foreground" Value="{StaticResource GoldDarkBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E4D5B8" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TextButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource GoldDarkBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="Monogram" TargetType="Border">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="42" />
        <Setter Property="CornerRadius" Value="21" />
        <Setter Property="Background" Value="#EEE1C7" />
        <Setter Property="BorderBrush" Value="#D9C59E" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="VisibleWhenTrue" TargetType="FrameworkElement">
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="VisibleWhenFalse" TargetType="FrameworkElement">
        <Setter Property="Visibility" Value="Visible" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding}" Value="True">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Input" TargetType="TextBox">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CaretBrush" Value="{StaticResource GoldBrush}" />
    </Style>

    <Style x:Key="Notice" TargetType="Border">
        <Setter Property="Background" Value="#FFF3DA" />
        <Setter Property="BorderBrush" Value="#E1C17E" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    </Style>
</ResourceDictionary>

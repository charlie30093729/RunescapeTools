<UserControl x:Class="RunescapePriceChecker.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="32,28,32,34">
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="OVERVIEW" Style="{StaticResource Kicker}" />
                    <TextBlock Text="Your market, minus the noise." Style="{StaticResource PageTitle}" Margin="0,4,0,0" />
                    <TextBlock Text="Only favourites and items used by your calculators are brought into view."
                               Foreground="{StaticResource MutedBrush}" FontSize="14" Margin="0,7,0,0" />
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Content="Manage favourites  →" Style="{StaticResource PrimaryButton}"
                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Favourites" />
            </Grid>

            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,8,0" Background="#F0E2C4" BorderBrush="#D6BA82">
                    <StackPanel>
                        <TextBlock Text="FOCUS LIST" Style="{StaticResource Kicker}" />
                        <TextBlock Text="{Binding FavouriteCount}" FontFamily="Georgia" FontSize="35" FontWeight="Bold" Margin="0,9,0,0" />
                        <TextBlock Text="favourite items" Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Panel}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="CALCULATORS" Style="{StaticResource Kicker}" />
                        <TextBlock Text="{Binding MethodCount}" FontFamily="Georgia" FontSize="35" FontWeight="Bold" Margin="0,9,0,0" />
                        <TextBlock Text="modular money makers" Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Panel}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="HISTORY WINDOW" Style="{StaticResource Kicker}" />
                        <TextBlock Text="{Binding HistoryWindow}" FontFamily="Georgia" FontSize="35" FontWeight="Bold" Margin="0,9,0,0" />
                        <TextBlock Text="hourly market points" Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" MinWidth="450" />
                    <ColumnDefinition Width="*" MinWidth="310" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="QUICK GLANCE" Style="{StaticResource Kicker}" />
                                <TextBlock Text="Favourite prices" Style="{StaticResource SectionTitle}" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="Open history  →" Style="{StaticResource TextButton}"
                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="Favourites" />
                        </Grid>

                        <Border Margin="0,0,0,12">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Notice}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers><DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger><DataTrigger Binding="{Binding ErrorMessage}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#805415" />
                        </Border>

                        <ItemsControl ItemsSource="{Binding Prices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource Monogram}">
                                                <TextBlock Text="{Binding Monogram}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource GoldDarkBrush}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ItemId, StringFormat=Item {0}}" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Price}" FontWeight="Bold" />
                                                <TextBlock Text="mid price" Foreground="{StaticResource MutedBrush}" FontSize="11" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No favourites yet. Add an item to begin collecting its weekly view."
                                   Foreground="{StaticResource MutedBrush}" Padding="0,22" HorizontalAlignment="Center">
                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasPrices}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Panel}" Margin="10,0,0,0" Background="#252B26">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="BUILT TO EXTEND" Style="{StaticResource Kicker}" Foreground="#D9AE61" />
                        <TextBlock Text="One calculation language" FontFamily="Georgia" FontSize="24" FontWeight="SemiBold" Foreground="White" Margin="0,7,0,12" />
                        <TextBlock Text="Every method describes what it consumes and what it produces. The shared engine prices those flows, applies tax, and calculates GP per hour."
                                   Foreground="#C9CEC8" LineHeight="21" />
                        <Border Background="#1D211E" CornerRadius="5" Padding="14" Margin="0,20,0,20">
                            <TextBlock Text="Inputs / hr   −   Output tax   +   Sales / hr" Foreground="#E5D1A8" HorizontalAlignment="Center" FontWeight="SemiBold" />
                        </Border>
                        <Button Content="View calculators" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="MoneyMakers" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="RunescapeTools.Wpf.Views.XpPlannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="30,24,30,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel>
                <TextBlock Text="EFFICIENT TRAINING" Style="{StaticResource Kicker}" />
                <TextBlock Text="XP Planner" Style="{StaticResource PageTitle}" Margin="0,3,0,0" />
                <TextBlock Text="Level-aware hours from your current profile to 99 or 200m, with live GP coverage as methods are verified."
                           Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,5,0,0" />
                <TextBlock Text="{Binding CatalogueLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="All to 99" Style="{StaticResource SecondaryButton}" Command="{Binding SetAllTo99Command}" Margin="0,0,8,0" />
                <Button Content="All to 200m" Style="{StaticResource SecondaryButton}" Command="{Binding SetAllTo200MCommand}" Margin="0,0,8,0" />
                <Button Content="Refresh prices" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshPricesCommand}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="16" Margin="0,0,6,0">
                <StackPanel><TextBlock Text="XP REMAINING" Style="{StaticResource Kicker}" FontSize="9" /><TextBlock Text="{Binding TotalExperienceRemaining}" FontFamily="Georgia" FontSize="23" FontWeight="Bold" Margin="0,5,0,0" /></StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Panel}" Padding="16" Margin="6,0">
                <StackPanel><TextBlock Text="ACTIVE HOURS" Style="{StaticResource Kicker}" FontSize="9" /><TextBlock Text="{Binding TotalHours}" FontFamily="Georgia" FontSize="23" FontWeight="Bold" Margin="0,5,0,0" /></StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="16" Margin="6,0">
                <StackPanel><TextBlock Text="PRICED NET GP" Style="{StaticResource Kicker}" FontSize="9" /><TextBlock Text="{Binding TotalNetGp}" FontFamily="Georgia" FontSize="21" FontWeight="Bold" Margin="0,5,0,0" /></StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Panel}" Padding="16" Margin="6,0,0,0">
                <StackPanel><TextBlock Text="ECONOMIC COVERAGE" Style="{StaticResource Kicker}" FontSize="9" /><TextBlock Text="{Binding PricedCoverage}" FontFamily="Georgia" FontSize="23" FontWeight="Bold" Margin="0,5,0,0" /></StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Notice}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#805415" />
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{Binding ProfileName, StringFormat=Profile: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,12,0" />
                <Button Content="Reset starts from profile" Style="{StaticResource TextButton}" Command="{Binding ResetFromProfileCommand}" />
                <TextBlock Text="{Binding SaveStatus}" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="12,0,0,0" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource Panel}" Padding="0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid MinWidth="1050">
                    <Grid.RowDefinitions><RowDefinition Height="38" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Grid Background="#E8DECA">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="145" /><ColumnDefinition Width="120" /><ColumnDefinition Width="120" />
                            <ColumnDefinition Width="250" /><ColumnDefinition Width="120" /><ColumnDefinition Width="80" />
                            <ColumnDefinition Width="130" /><ColumnDefinition Width="85" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SKILL" Grid.Column="0" Margin="14,0" VerticalAlignment="Center" Style="{StaticResource Kicker}" FontSize="9" />
                        <TextBlock Text="START XP" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource Kicker}" FontSize="9" />
                        <TextBlock Text="GOAL XP" Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource Kicker}" FontSize="9" />
                        <TextBlock Text="CURRENT METHOD" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource Kicker}" FontSize="9" />
                        <TextBlock Text="XP / HOUR" Grid.Column="4" VerticalAlignment="Center" Style="{StaticResource Kicker}" FontSize="9" />
                        <TextBlock Text="HOURS" Grid.Column="5" VerticalAlignment="Center" Style="{StaticResource Kicker}" FontSize="9" />
                        <TextBlock Text="TOTAL GP" Grid.Column="6" VerticalAlignment="Center" Style="{StaticResource Kicker}" FontSize="9" />
                        <TextBlock Text="COVERAGE" Grid.Column="7" VerticalAlignment="Center" Style="{StaticResource Kicker}" FontSize="9" />
                    </Grid>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="58" Background="#FCFAF4" ToolTip="{Binding Note}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" /><ColumnDefinition Width="120" /><ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="250" /><ColumnDefinition Width="120" /><ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="130" /><ColumnDefinition Width="85" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="8" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" />
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,7" VerticalAlignment="Center">
                                        <Border Width="34" Height="34" CornerRadius="17" Background="#272C28" Margin="0,0,9,0">
                                            <Image Source="{Binding IconUrl}" Width="23" Height="23" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" ImageFailed="SkillIconFailed" />
                                        </Border>
                                        <TextBlock Text="{Binding Skill}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding StartExperience, UpdateSourceTrigger=LostFocus}" Style="{StaticResource Input}" Margin="0,9,8,9" Padding="8,5" FontSize="12" VerticalContentAlignment="Center" />
                                    <TextBox Grid.Column="2" Text="{Binding TargetExperience, UpdateSourceTrigger=LostFocus}" Style="{StaticResource Input}" Margin="0,9,8,9" Padding="8,5" FontSize="12" VerticalContentAlignment="Center" />
                                    <StackPanel Grid.Column="3" Margin="0,8,12,8" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Method}" FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                        <TextBlock Text="{Binding GpPerHour}" Foreground="{StaticResource MutedBrush}" FontSize="9" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Grid Grid.Column="4" Margin="0,9,8,9">
                                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="28" /></Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding PersonalRate, UpdateSourceTrigger=LostFocus, StringFormat=0}" Style="{StaticResource Input}" Padding="8,5" FontSize="12" VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1" Content="↺" Command="{Binding ResetRateCommand}" Style="{StaticResource TextButton}" Margin="3,0,0,0" Padding="0" FontSize="16" ToolTip="Reset XP/hour to the current method's original rate" AutomationProperties.Name="Reset XP rate" />
                                    </Grid>
                                    <TextBlock Grid.Column="5" Text="{Binding Hours}" FontFamily="Georgia" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="6" Text="{Binding TotalGp}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="NoWrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource NegativeBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsProfit}" Value="True"><Setter Property="Foreground" Value="{StaticResource PositiveBrush}" /></DataTrigger></Style.Triggers></Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="7" Text="{Binding PricingStatus}" Foreground="{StaticResource MutedBrush}" FontSize="9" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.RowSpan="4" Background="#A0FBF8EF">
            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsLoading}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><ProgressBar Width="180" Height="5" IsIndeterminate="True" Foreground="{StaticResource GoldBrush}" /><TextBlock Text="Loading EHP catalogue and live prices..." Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" /></StackPanel>
        </Border>
    </Grid>
</UserControl>

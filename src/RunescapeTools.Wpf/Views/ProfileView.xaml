<UserControl x:Class="RunescapeTools.Wpf.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="32,28,32,34">
            <Grid Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="PLAYER PROFILE" Style="{StaticResource Kicker}" />
                    <TextBlock Text="Old School Hiscores" Style="{StaticResource PageTitle}" Margin="0,4,0,0" />
                    <TextBlock Text="Load an account once, then share its complete skill state with every tool in the workspace."
                               Foreground="{StaticResource MutedBrush}" FontSize="14" Margin="0,7,0,0" />
                </StackPanel>
            </Grid>

            <Border Style="{StaticResource Panel}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="ACCOUNT LOOKUP" Style="{StaticResource Kicker}" />
                        <Grid Margin="0,9,20,0" MaxWidth="650" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SearchRsn, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}" AutomationProperties.Name="RuneScape account name">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="Load profile" Command="{Binding SearchCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" />
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Refresh current" Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,14">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>

            <Border Margin="0,0,0,16">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Notice}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource NegativeBrush}" />
            </Border>

            <Border Style="{StaticResource Panel}" Margin="0,0,0,18" Background="#252B26" Padding="22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="CURRENT ACCOUNT" Style="{StaticResource Kicker}" Foreground="#D9AE61" />
                        <TextBlock Text="{Binding ProfileRsn}" FontFamily="Georgia" FontSize="26" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="TOTAL LEVEL" Foreground="#AEB5AE" FontSize="10" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalLevel}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,5,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="OVERALL" Foreground="#AEB5AE" FontSize="10" FontWeight="Bold" />
                        <TextBlock Text="{Binding OverallRank}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,7,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="EXPERIENCE" Foreground="#AEB5AE" FontSize="10" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalExperience}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,7,0,0" />
                        <TextBlock Text="{Binding RetrievedAt}" Foreground="#AEB5AE" FontSize="10" Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding Skills}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Panel}" Padding="14" Margin="4" MinHeight="92">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource Monogram}" Width="38" Height="38" CornerRadius="19">
                                    <TextBlock Text="{Binding Monogram}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" FontSize="11" Foreground="{StaticResource GoldDarkBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <Grid>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Level}" HorizontalAlignment="Right" FontFamily="Georgia" FontSize="21" FontWeight="Bold" />
                                    </Grid>
                                    <TextBlock Text="{Binding Experience}" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding Rank}" Foreground="{StaticResource GoldDarkBrush}" FontSize="10" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

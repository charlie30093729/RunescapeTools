<Window x:Class="RunescapeTools.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RunescapeTools.Wpf.ViewModels"
        xmlns:views="clr-namespace:RunescapeTools.Wpf.Views"
        Title="GE Ledger · RunescapeTools"
        Width="1280" Height="800" MinWidth="1100" MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
            <views:ProfileView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FavouritesViewModel}">
            <views:FavouritesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MoneyMakersViewModel}">
            <views:MoneyMakersView />
        </DataTemplate>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SidebarMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#2A312B" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PaperBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid Margin="22,24,22,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="7" Background="#A16F1D">
                        <TextBlock Text="GE" FontFamily="Georgia" FontWeight="Bold" FontSize="18"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,3,0,0">
                        <TextBlock Text="GE LEDGER" Foreground="White" FontWeight="Bold" FontSize="15" />
                        <TextBlock Text="MARKET WORKSPACE" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10" Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1" Height="1" Background="#343C35" Margin="0,24,0,18" />

                <StackPanel Grid.Row="2">
                    <TextBlock Text="WORKSPACE" Foreground="#778078" FontSize="10" FontWeight="Bold" Margin="16,0,0,8" />
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Profile" AutomationProperties.Name="Profile">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="◎" FontSize="18" Width="30" /><TextBlock Text="Profile" VerticalAlignment="Center" /></StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers><DataTrigger Binding="{Binding IsProfileSelected}" Value="True"><Setter Property="Background" Value="#394334" /><Setter Property="Foreground" Value="White" /></DataTrigger></Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Dashboard" AutomationProperties.Name="Dashboard">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="⌂" FontSize="18" Width="30" /><TextBlock Text="Dashboard" VerticalAlignment="Center" /></StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers><DataTrigger Binding="{Binding IsDashboardSelected}" Value="True"><Setter Property="Background" Value="#394334" /><Setter Property="Foreground" Value="White" /></DataTrigger></Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Favourites" AutomationProperties.Name="Favourites">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers><DataTrigger Binding="{Binding IsFavouritesSelected}" Value="True"><Setter Property="Background" Value="#394334" /><Setter Property="Foreground" Value="White" /></DataTrigger></Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="☆" FontSize="18" Width="30" /><TextBlock Text="Favourites" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="MoneyMakers" AutomationProperties.Name="Money Makers">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers><DataTrigger Binding="{Binding IsMoneyMakersSelected}" Value="True"><Setter Property="Background" Value="#394334" /><Setter Property="Foreground" Value="White" /></DataTrigger></Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="◈" FontSize="17" Width="30" /><TextBlock Text="Money Makers" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3" BorderBrush="#343C35" BorderThickness="0,1,0,0" Padding="4,16,4,0">
                    <StackPanel>
                        <TextBlock Text="OSRS WIKI PRICES" Foreground="#879088" FontSize="10" FontWeight="Bold" />
                        <TextBlock Text="Live Grand Exchange data" Foreground="{StaticResource SidebarMutedBrush}" FontSize="12" Margin="0,4,0,0" />
                        <TextBlock Text="This application is not affiliated with, endorsed, or otherwise approved by Jagex Ltd. RuneScape and Old School RuneScape are trademarks of Jagex Ltd."
                                   Foreground="#899188" FontSize="9" LineHeight="13" Margin="0,14,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Background="#F8F3E7">
                <Grid Margin="32,0">
                    <TextBlock Text="{Binding Today}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="12" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#3C925F" Margin="0,0,7,0" />
                        <TextBlock Text="Market service ready" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
